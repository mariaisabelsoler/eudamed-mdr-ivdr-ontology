  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InjuryRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk of thrombus formation on the device surface, which can cause embolic events such as stroke. Critical for implantable cardiovascular devices."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Thrombosis - device-related"
  }, {
    "@language" : "ca",
    "@value" : "Trombosi relacionada amb el dispositiu"
  } ],
  "http://xmlns.com/foaf/0.1/name" : [ {
    "@value" : "Thrombosis - device-related"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RadiationRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk caused by radiation that comes from the device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Radiation Risk"
  }, {
    "@language" : "ca",
    "@value" : "Risc de Radiació"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Risk"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Recall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corrective action where the affected devices are removed from the market."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Recall"
  }, {
    "@language" : "ca",
    "@value" : "Retirada del Mercat"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#CorrectiveAction"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RegulatoryFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The European regulation that controls a medical device. It can be MDR or IVDR."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Marc Regulatori"
  }, {
