    "@id" : "_:genid77"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RiskClass",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Regulatory class of a medical device by risk level. It is defined by MDR (I, IIa, IIb, III) or by IVDR (A, B, C, D)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Classe de Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk Class"
  } ]
