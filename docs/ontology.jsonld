}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@language" : "en",
    "@value" : "Maria Isabel Soler"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "The purpose of the ontology is to model the domain of medical devices and in vitro diagnostic devices registered in the European EUDAMED database, including manufacturers, identified risks, incidents, and field safety corrective actions (FSCAs). The goal is to enable the different information systems in the sector — manufacturers, regulatory authorities, hospitals, and patients — to share data accurately, without ambiguity, and to interoperate easily with each other."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "EUDAMED MDR-IVDR Ontology"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-26"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespacePrefix" : [ {
    "@value" : "eudamed"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespaceUri" : [ {
    "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EUDAMED MDR-IVDR Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr/1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0.0"
  } ]
}, {
