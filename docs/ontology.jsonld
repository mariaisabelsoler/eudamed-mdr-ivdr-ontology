  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A company or person that designs and produces medical devices. Manufacturers must register their devices in EUDAMED."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Fabricant"
  }, {
    "@language" : "en",
    "@value" : "Manufacturer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MaterialRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk caused by the materials used in the device, such as toxicity or wear."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Material Risk"
  }, {
    "@language" : "ca",
    "@value" : "Risc de Materials"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device used for medical purposes such as diagnosis, prevention, or treatment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Dispositiu Mèdic"
  }, {
    "@language" : "en",
    "@value" : "Medical Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://schema.org/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Medium",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Medium probability that the risk happens."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Medium"
  }, {
    "@language" : "ca",
    "@value" : "Mitjana"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Moderate",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Moderate level of severity. The risk can cause limited harm to the patient."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Moderat"
  }, {
    "@language" : "en",
    "@value" : "Moderate"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/NearMissIncident",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An event that did not cause harm, but that could have been a serious incident."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Near-Miss Incident"
  }, {
    "@language" : "ca",
    "@value" : "Quasi-Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The corrective action is still in progress."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Obert"
  }, {
    "@language" : "en",
    "@value" : "Open"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk category related to physical harm to the patient."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Dany al Pacient"
  }, {
    "@language" : "en",
    "@value" : "Patient Harm"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "How likely a risk is to happen. The possible values are Low, Medium, or High."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Probabilitat"
  }, {
    "@language" : "en",
    "@value" : "Probability"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid33"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk category related to the quality of the product."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Product Quality"
  }, {
    "@language" : "ca",
    "@value" : "Qualitat del Producte"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RadiationRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk caused by radiation that comes from the device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Radiation Risk"
  }, {
    "@language" : "ca",
    "@value" : "Risc de Radiació"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
