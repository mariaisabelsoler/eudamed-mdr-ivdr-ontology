    "@language" : "en",
    "@value" : "Soler, Maria Isabel (2026). EUDAMED MDR-IVDR Ontology. Universitat Oberta de Catalunya (UOC)."
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-26"
  } ],
