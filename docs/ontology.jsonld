  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corrective action where the affected devices are removed from the market."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Recall"
  }, {
    "@language" : "ca",
    "@value" : "Retirada del Mercat"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The European regulation that controls a medical device. It can be MDR or IVDR."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Marc Regulatori"
  }, {
    "@language" : "en",
    "@value" : "Regulatory Framework"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid37"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A group of countries where a corrective action applies. For example, EU-wide or EU-wide plus UK."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Regulatory Zone"
  }, {
    "@language" : "ca",
    "@value" : "Zona Regulatòria"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An agent that can report medical device incidents. It can be a manufacturer, an authority, a healthcare professional, or a patient."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Entitat Reportadora"
  }, {
    "@language" : "en",
    "@value" : "Reporting Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Agent"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A possible problem related to the use of a medical device. Each risk has a type, a category, a severity, and a probability."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "General classification of a risk. It can be device failure, patient harm, performance, safety, diagnostic error, or product quality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Categoria de Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk Category"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid40"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Regulatory class of a medical device by risk level. It is defined by MDR (I, IIa, IIb, III) or by IVDR (A, B, C, D)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Classe de Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk Class"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A message sent to users about a safety problem with a device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Alerta de Seguretat"
  }, {
    "@language" : "en",
    "@value" : "Safety Alert"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SelfTestDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An in vitro diagnostic device that people can use at home, without medical staff."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Dispositiu d'Autodiagnòstic"
  }, {
    "@language" : "en",
    "@value" : "Self-Test Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Serious level of severity. The risk can cause important harm to the patient."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Greu"
  }, {
    "@language" : "en",
    "@value" : "Serious"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An incident that caused or could cause death or serious health problems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Incident Greu"
  }, {
    "@language" : "en",
    "@value" : "Serious Incident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Level of how serious a risk is. The possible values are Critical, Serious, or Moderate."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Gravetat"
  }, {
    "@language" : "en",
    "@value" : "Severity"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid47"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Sex of a patient involved in an incident. The possible values are Male or Female."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Sex"
  }, {
    "@language" : "ca",
    "@value" : "Sexe"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid51"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A medical device used only once on a single patient. Implantable devices are also single-use."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Dispositiu d'un Sol Ús"
  }, {
    "@language" : "en",
    "@value" : "Single-Use Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SoftwareRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk caused by errors or bugs in the device software."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Risc de Programari"
  }, {
    "@language" : "en",
    "@value" : "Software Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/UserNotice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A notice sent to users with instructions on how to use or limit the device."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Avís a Usuaris"
  }, {
    "@language" : "en",
    "@value" : "User Notice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/actionDate",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Date when the corrective action started."
