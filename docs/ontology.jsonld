    "@value" : "Reporting Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Agent"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Risk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A possible problem related to the use of a medical device. Each risk has a type, a category, a severity, and a probability."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid71"
  }, {
    "@id" : "_:genid72"
  }, {
    "@id" : "_:genid73"
  }, {
    "@id" : "_:genid74"
  }, {
    "@id" : "_:genid75"
  }, {
    "@id" : "_:genid76"
  } ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RiskCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "General classification of a risk. It can be device failure, patient harm, performance, safety, diagnostic error, or product quality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "ca",
    "@value" : "Categoria de Risc"
  }, {
    "@language" : "en",
    "@value" : "Risk Category"
  } ],
