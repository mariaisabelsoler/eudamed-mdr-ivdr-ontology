  "@id" : "http://schema.org/Country",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://schema.org/MedicalDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@language" : "en",
    "@value" : "Maria Isabel Soler"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "The purpose of the ontology is to model the domain of medical devices and in vitro diagnostic devices registered in the European EUDAMED database, including manufacturers, identified risks, incidents, and field safety corrective actions (FSCAs). The goal is to enable the different information systems in the sector — manufacturers, regulatory authorities, hospitals, and patients — to share data accurately, without ambiguity, and to interoperate easily with each other."
  } ],
  "http://purl.org/dc/elements/1.1/source" : [ {
    "@language" : "en",
    "@value" : "EUDAMED public repository, https://ec.europa.eu/tools/eudamed/"
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "EUDAMED MDR-IVDR Ontology"
  } ],
