    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#DEV-001 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#DEV-001">
        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice"/>
        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice"/>
        <untitled-ontology-9:hasManufacturer rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MAN-001"/>
        <untitled-ontology-9:hasRegulatoryFramework rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR"/>
        <untitled-ontology-9:hasRiskClass rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII"/>
        <untitled-ontology-9:intendedPurpose>Ventricular assist device for end-stage heart failure</untitled-ontology-9:intendedPurpose>
        <untitled-ontology-9:isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</untitled-ontology-9:isActive>
        <untitled-ontology-9:isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</untitled-ontology-9:isImplantable>
        <untitled-ontology-9:isIvd rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</untitled-ontology-9:isIvd>
        <untitled-ontology-9:isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</untitled-ontology-9:isReusable>
        <untitled-ontology-9:udiDi>(01)00380740009095</untitled-ontology-9:udiDi>
        <foaf:name>HeartMate 3 LVAD</foaf:name>
        <rdfs:comment xml:lang="en">Left ventricular assist device used for end-stage heart failure. It is a centrifugal-flow pump that supports cardiac function in patients waiting for a heart transplant or as a long-term solution.</rdfs:comment>
        <rdfs:label xml:lang="ca">HeartMate 3 LVAD</rdfs:label>
        <rdfs:label xml:lang="en">HeartMate 3 LVAD</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#EUWide -->


