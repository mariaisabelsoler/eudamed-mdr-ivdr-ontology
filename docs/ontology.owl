<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#"
     xml:base="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/preferredNamespacePrefix#vann:"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:untitled-ontology-9="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/">
    <owl:Ontology rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr">
        <owl:versionIRI rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr/1.0.0"/>
        <dc:creator xml:lang="en">Maria Isabel Soler</dc:creator>
        <dc:description xml:lang="en">The purpose of the ontology is to model the domain of medical devices and in vitro diagnostic devices registered in the European EUDAMED database, including manufacturers, identified risks, incidents, and field safety corrective actions (FSCAs). The goal is to enable the different information systems in the sector — manufacturers, regulatory authorities, hospitals, and patients — to share data accurately, without ambiguity, and to interoperate easily with each other.</dc:description>
        <dc:title xml:lang="en">EUDAMED MDR-IVDR Ontology</dc:title>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-26</terms:created>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <vann:preferredNamespacePrefix>eudamed</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#"/>
        <rdfs:label xml:lang="en">EUDAMED MDR-IVDR Ontology</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


