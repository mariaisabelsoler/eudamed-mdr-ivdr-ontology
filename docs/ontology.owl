    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespacePrefix">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix#vann:preferredNamespaceUri">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs"/>
    


    <!-- http://www.w3.org/2002/07/owl#versionInfo -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#versionInfo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#label"/>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/addressesIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:comment xml:lang="en">Connects a corrective action to the incident that it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
        <rdfs:label xml:lang="ca">tracta l&apos;incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/affectedDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/affectedDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">Connects a risk to the types of medical devices that it can affect.</rdfs:comment>
        <rdfs:label xml:lang="en">affected device type</rdfs:label>
        <rdfs:label xml:lang="ca">tipus de dispositiu afectat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/category -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/category">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory"/>
        <rdfs:comment xml:lang="en">Connects a risk to its general category.</rdfs:comment>
        <rdfs:label xml:lang="ca">categoria</rdfs:label>
        <rdfs:label xml:lang="en">category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countriesAffected -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countriesAffected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope"/>
        <rdfs:comment xml:lang="en">Geographic area affected by a corrective action. It can be a single country or a regulatory zone.</rdfs:comment>
        <rdfs:label xml:lang="en">countries affected</rdfs:label>
        <rdfs:label xml:lang="ca">països afectats</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countryReported -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countryReported">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country"/>
        <rdfs:comment xml:lang="en">Country where the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">country reported</rdfs:label>
        <rdfs:label xml:lang="ca">país on s&apos;ha reportat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCompetentAuthority -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCompetentAuthority">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Connects a manufacturer to its competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">has competent authority</rdfs:label>
        <rdfs:label xml:lang="ca">té autoritat competent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country"/>
        <rdfs:comment xml:lang="en">Connects a manufacturer to its country of registration.</rdfs:comment>
        <rdfs:label xml:lang="en">has country</rdfs:label>
        <rdfs:label xml:lang="ca">té país</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:comment xml:lang="en">Connects a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
        <rdfs:label xml:lang="ca">té fabricant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRegulatoryFramework">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Indicates the EU regulation that applies to a device. It can be MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">has regulatory framework</rdfs:label>
        <rdfs:label xml:lang="ca">té marc regulatori</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasReportingEntity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasReportingEntity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity"/>
        <rdfs:comment xml:lang="en">Connects an incident to the entity that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">has reporting entity</rdfs:label>
        <rdfs:label xml:lang="ca">té entitat reportadora</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRiskClass">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass"/>
        <rdfs:comment xml:lang="en">Connects a device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
        <rdfs:label xml:lang="ca">té classe de risc</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/involvesDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">Connects an incident to the medical device involved.</rdfs:comment>
        <rdfs:label xml:lang="ca">involucra dispositiu</rdfs:label>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/materializesRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/materializesRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Connects an incident to the risks that happened in it.</rdfs:comment>
        <rdfs:label xml:lang="ca">materialitza risc</rdfs:label>
        <rdfs:label xml:lang="en">materializes risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientSex -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex"/>
        <rdfs:comment xml:lang="en">Indicates the sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">patient sex</rdfs:label>
        <rdfs:label xml:lang="ca">sexe del pacient</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/probability -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/probability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability"/>
        <rdfs:comment xml:lang="en">Connects a risk to its probability level.</rdfs:comment>
        <rdfs:label xml:lang="ca">probabilitat</rdfs:label>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/severity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/severity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity"/>
        <rdfs:comment xml:lang="en">Connects a risk to its severity level.</rdfs:comment>
        <rdfs:label xml:lang="ca">gravetat</rdfs:label>
        <rdfs:label xml:lang="en">severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/status -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/status">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus"/>
        <rdfs:comment xml:lang="en">Current status of a corrective action. It can be Open or Closed.</rdfs:comment>
        <rdfs:label xml:lang="ca">estat</rdfs:label>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/actionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the corrective action started.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
        <rdfs:label xml:lang="ca">data de l&apos;acció</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/authorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authorization number assigned to a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
        <rdfs:label xml:lang="ca">número d&apos;autorització</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/closureDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/closureDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure date</rdfs:label>
        <rdfs:label xml:lang="ca">data de tancament</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/contactEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Email address used to contact the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
        <rdfs:label xml:lang="ca">correu de contacte</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/correctiveActionTaken">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if a corrective action was taken after the incident.</rdfs:comment>
        <rdfs:label xml:lang="ca">acció correctiva realitzada</rdfs:label>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/description -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/description">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Text description of the entity, such as a risk, an incident, or a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="ca">descripció</rdfs:label>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/detectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/detectionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="ca">data de detecció</rdfs:label>
        <rdfs:label xml:lang="en">detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/devicesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of devices affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
        <rdfs:label xml:lang="ca">dispositius afectats</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedFscaRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference number of the corrective action in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED FSCA reference</rdfs:label>
        <rdfs:label xml:lang="ca">referència FSCA a EUDAMED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedIncidentRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference number of the incident in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED incident reference</rdfs:label>
        <rdfs:label xml:lang="ca">referència d&apos;incident a EUDAMED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedSrn -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedSrn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number of the manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED SRN</rdfs:label>
        <rdfs:label xml:lang="ca">SRN d&apos;EUDAMED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident happened.</rdfs:comment>
        <rdfs:label xml:lang="ca">data de l&apos;esdeveniment</rdfs:label>
        <rdfs:label xml:lang="en">event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/imdrfCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Code from the IMDRF (International Medical Device Regulators Forum) used to classify the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF code</rdfs:label>
        <rdfs:label xml:lang="ca">codi IMDRF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/intendedPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The use for which the manufacturer designed the device.</rdfs:comment>
        <rdfs:label xml:lang="en">intended purpose</rdfs:label>
        <rdfs:label xml:lang="ca">ús previst</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isActive -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the device needs an external energy source to work.</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
        <rdfs:label xml:lang="ca">és actiu</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the device is implantable inside the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
        <rdfs:label xml:lang="ca">és implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the device is for in vitro diagnostic use.</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
        <rdfs:label xml:lang="ca">és IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the device can be used more than once.</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
        <rdfs:label xml:lang="ca">és reutilitzable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/outcome -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/outcome">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of what happened as a result of the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">outcome</rdfs:label>
        <rdfs:label xml:lang="ca">resultat</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientAge -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientAge">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="ca">edat del pacient</rdfs:label>
        <rdfs:label xml:lang="en">patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/reportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="ca">data de report</rdfs:label>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/scope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/scope">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the scope of the corrective action, such as the affected lots or models.</rdfs:comment>
        <rdfs:label xml:lang="ca">abast</rdfs:label>
        <rdfs:label xml:lang="en">scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/udiDi -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/udiDi">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique Device Identifier - Device Identifier. It is the unique code of a medical device under MDR.</rdfs:comment>
        <rdfs:label xml:lang="ca">UDI-DI</rdfs:label>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://schema.org/Country -->


    <owl:Class rdf:about="http://schema.org/Country"/>
    


    <!-- http://schema.org/MedicalDevice -->


    <owl:Class rdf:about="http://schema.org/MedicalDevice"/>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Closed"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Status of a corrective action. The possible values are Open or Closed.</rdfs:comment>
        <rdfs:label xml:lang="en">Action Status</rdfs:label>
        <rdfs:label xml:lang="ca">Estat de l&apos;Acció</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device that needs an electrical source or another type of energy to work.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
        <rdfs:label xml:lang="ca">Dispositiu Actiu</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity"/>
        <rdfs:comment xml:lang="en">The national authority in each EU country responsible for medical device regulation.</rdfs:comment>
        <rdfs:label xml:lang="ca">Autoritat Competent</rdfs:label>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ContaminationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk that the device or the patient gets contaminated.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de Contaminació</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ActiveDeviceType"/>
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableActiveDeviceType"/>
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableDeviceType"/>
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDeviceType"/>
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SelfTestDeviceType"/>
                    <rdf:Description rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SingleUseDeviceType"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A Field Safety Corrective Action. It is any action a manufacturer takes to reduce a risk, such as a recall, a safety alert, or a user notice.</rdfs:comment>
        <rdfs:label xml:lang="ca">Acció Correctiva (FSCA)</rdfs:label>
        <rdfs:label xml:lang="en">Corrective Action (FSCA)</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country">
        <rdfs:subClassOf rdf:resource="http://schema.org/Country"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone"/>
        <rdfs:comment xml:lang="en">A country, used to identify where manufacturers are registered or where incidents are reported.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
        <rdfs:label xml:lang="ca">País</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CybersecurityRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk of unauthorized access or attacks on connected medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de Ciberseguretat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk of wrong diagnostic results, such as false positives or false negatives.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc Diagnòstic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope">
        <rdfs:comment xml:lang="en">A general class for geographic areas. It includes both single countries and regulatory zones.</rdfs:comment>
        <rdfs:label xml:lang="en">Geographic Scope</rdfs:label>
        <rdfs:label xml:lang="ca">Àmbit Geogràfic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDRRiskClass">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassA"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassB"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassC"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassD"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass"/>
        <rdfs:comment xml:lang="en">Risk class for in vitro diagnostic devices under IVDR. The possible values are A, B, C, or D.</rdfs:comment>
        <rdfs:label xml:lang="ca">Classe de Risc IVDR</rdfs:label>
        <rdfs:label xml:lang="en">IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableActiveDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device that is both implantable and active. For example, a pacemaker.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu Actiu Implantable</rdfs:label>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">A medical device that is placed inside the human body and stays there after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu Implantable</rdfs:label>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InSituCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action done on devices that are already in use, without removing them from the market.</rdfs:comment>
        <rdfs:label xml:lang="ca">Correcció In Situ</rdfs:label>
        <rdfs:label xml:lang="en">In-Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device used to analyse samples from the human body, such as blood or urine.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu de Diagnòstic In Vitro</rdfs:label>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident">
        <rdfs:comment xml:lang="en">An adverse event that happens with a medical device. Manufacturers must report incidents under MDR Article 87.</rdfs:comment>
        <rdfs:label xml:lang="ca">Incident</rdfs:label>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InfectionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk of infection due to contamination or poor sterilization of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc d&apos;Infecció</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk of physical harm to the patient caused by the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de Lesió</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InterferenceRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk that the device gets disturbed by other devices, or that it disturbs other devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc d&apos;Interferència</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassI"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIa"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIb"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass"/>
        <rdfs:comment xml:lang="en">Risk class for devices under MDR. The possible values are I, IIa, IIb, or III.</rdfs:comment>
        <rdfs:label xml:lang="ca">Classe de Risc MDR</rdfs:label>
        <rdfs:label xml:lang="en">MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MalfunctionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk that the device fails or stops working correctly.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de mal funcionament</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity"/>
        <rdfs:comment xml:lang="en">A company or person that designs and produces medical devices. Manufacturers must register their devices in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="ca">Fabricant</rdfs:label>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MaterialRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk caused by the materials used in the device, such as toxicity or wear.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de Materials</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://schema.org/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device used for medical purposes such as diagnosis, prevention, or treatment.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu Mèdic</rdfs:label>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/NearMissIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident"/>
        <rdfs:comment xml:lang="en">An event that did not cause harm, but that could have been a serious incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Near-Miss Incident</rdfs:label>
        <rdfs:label xml:lang="ca">Quasi-Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/High"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Low"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Medium"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">How likely a risk is to happen. The possible values are Low, Medium, or High.</rdfs:comment>
        <rdfs:label xml:lang="ca">Probabilitat</rdfs:label>
        <rdfs:label xml:lang="en">Probability</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RadiationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk"/>
        <rdfs:comment xml:lang="en">Risk caused by radiation that comes from the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
        <rdfs:label xml:lang="ca">Risc de Radiació</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action where the affected devices are removed from the market.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
        <rdfs:label xml:lang="ca">Retirada del Mercat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDR"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">The European regulation that controls a medical device. It can be MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="ca">Marc Regulatori</rdfs:label>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope"/>
        <rdfs:comment xml:lang="en">A group of countries where a corrective action applies. For example, EU-wide or EU-wide plus UK.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Zone</rdfs:label>
        <rdfs:label xml:lang="ca">Zona Regulatòria</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment xml:lang="en">An agent that can report medical device incidents. It can be a manufacturer, an authority, a healthcare professional, or a patient.</rdfs:comment>
        <rdfs:label xml:lang="ca">Entitat Reportadora</rdfs:label>
        <rdfs:label xml:lang="en">Reporting Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk">
        <rdfs:comment xml:lang="en">A possible problem related to the use of a medical device. Each risk has a type, a category, a severity, and a probability.</rdfs:comment>
        <rdfs:label xml:lang="ca">Risc</rdfs:label>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceFailure"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DevicePerformance"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceSafety"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticError"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">General classification of a risk. It can be device failure, patient harm, performance, safety, diagnostic error, or product quality.</rdfs:comment>
        <rdfs:label xml:lang="ca">Categoria de Risc</rdfs:label>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass">
        <rdfs:comment xml:lang="en">Regulatory class of a medical device by risk level. It is defined by MDR (I, IIa, IIb, III) or by IVDR (A, B, C, D).</rdfs:comment>
        <rdfs:label xml:lang="ca">Classe de Risc</rdfs:label>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A message sent to users about a safety problem with a device.</rdfs:comment>
        <rdfs:label xml:lang="ca">Alerta de Seguretat</rdfs:label>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SelfTestDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An in vitro diagnostic device that people can use at home, without medical staff.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu d&apos;Autodiagnòstic</rdfs:label>
        <rdfs:label xml:lang="en">Self-Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident"/>
        <rdfs:comment xml:lang="en">An incident that caused or could cause death or serious health problems.</rdfs:comment>
        <rdfs:label xml:lang="ca">Incident Greu</rdfs:label>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Critical"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Moderate"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Level of how serious a risk is. The possible values are Critical, Serious, or Moderate.</rdfs:comment>
        <rdfs:label xml:lang="ca">Gravetat</rdfs:label>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Female"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Male"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Sex of a patient involved in an incident. The possible values are Male or Female.</rdfs:comment>
        <rdfs:label xml:lang="en">Sex</rdfs:label>
        <rdfs:label xml:lang="ca">Sexe</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device used only once on a single patient. Implantable devices are also single-use.</rdfs:comment>
        <rdfs:label xml:lang="ca">Dispositiu d&apos;un Sol Ús</rdfs:label>
