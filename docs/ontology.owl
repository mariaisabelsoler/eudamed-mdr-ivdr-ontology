    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#INC-001 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#INC-001">
        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident"/>
        <untitled-ontology-9:countryReported rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Germany"/>
        <untitled-ontology-9:hasReportingEntity rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MAN-001"/>
        <untitled-ontology-9:involvesDevice rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#DEV-001"/>
        <untitled-ontology-9:materializesRisk rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RSK-003"/>
        <untitled-ontology-9:patientSex rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Male"/>
        <untitled-ontology-9:correctiveActionTaken rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</untitled-ontology-9:correctiveActionTaken>
        <untitled-ontology-9:description>Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant. Device thrombus confirmed by echocardiography.</untitled-ontology-9:description>
        <untitled-ontology-9:detectionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-10</untitled-ontology-9:detectionDate>
        <untitled-ontology-9:eudamedIncidentRef>EU-INC-2024-000001</untitled-ontology-9:eudamedIncidentRef>
        <untitled-ontology-9:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-08</untitled-ontology-9:eventDate>
        <untitled-ontology-9:outcome>Serious patient injury - embolic stroke</untitled-ontology-9:outcome>
        <untitled-ontology-9:patientAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">58</untitled-ontology-9:patientAge>
        <untitled-ontology-9:reportDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-15</untitled-ontology-9:reportDate>
        <rdfs:comment xml:lang="en">Serious incident reported in Germany in January 2024. A patient implanted with a HeartMate 3 LVAD developed an ischemic stroke six months after implantation. Device thrombus was confirmed by echocardiography.</rdfs:comment>
        <rdfs:label xml:lang="ca">Incident d&apos;ictus amb HeartMate 3 LVAD.</rdfs:label>
        <rdfs:label xml:lang="en">Stroke incident with HeartMate 3 LVAD.</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableActiveDeviceType -->


