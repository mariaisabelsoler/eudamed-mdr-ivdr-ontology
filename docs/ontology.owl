        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone"/>
        <rdfs:comment xml:lang="en">Regulatory zone covering all the European Union member states.</rdfs:comment>
        <rdfs:label xml:lang="en">EU-wide</rdfs:label>
        <rdfs:label xml:lang="ca">Tota la UE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#FSCA-001">
        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert"/>
        <untitled-ontology-9:addressesIncident rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#INC-001"/>
        <untitled-ontology-9:countriesAffected rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#EUWide"/>
        <untitled-ontology-9:status rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open"/>
        <untitled-ontology-9:actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</untitled-ontology-9:actionDate>
        <untitled-ontology-9:description>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</untitled-ontology-9:description>
        <untitled-ontology-9:devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</untitled-ontology-9:devicesAffected>
        <untitled-ontology-9:eudamedFscaRef>EU-FSCA-2024-000001</untitled-ontology-9:eudamedFscaRef>
        <untitled-ontology-9:scope>All HeartMate 3 LVAD units implanted since 2020</untitled-ontology-9:scope>
        <rdfs:comment xml:lang="en">Safety alert issued by Medtronic in February 2024 to all centres implanting HeartMate 3 LVAD. The alert updates the anticoagulation protocol to reduce device thrombosis risk.</rdfs:comment>
        <rdfs:label xml:lang="ca">Alerta de Seguretat per anticoagulació HeartMate 3 LVAD</rdfs:label>
        <rdfs:label xml:lang="en">Safety Alert for HeartMate 3 LVAD anticoagulation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Germany -->


