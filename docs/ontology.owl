    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RSK-003 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RSK-003">
        <rdf:type rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk"/>
        <untitled-ontology-9:affectedDeviceType rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableActiveDeviceType"/>
        <untitled-ontology-9:category rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm"/>
        <untitled-ontology-9:probability rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Low"/>
        <untitled-ontology-9:severity rdf:resource="http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Critical"/>
        <untitled-ontology-9:description>Thrombus formation on device surface causing embolic events</untitled-ontology-9:description>
        <untitled-ontology-9:imdrfCode>A0201</untitled-ontology-9:imdrfCode>
        <foaf:name>Thrombosis - device-related</foaf:name>
        <rdfs:comment xml:lang="en">Risk of thrombus formation on the device surface, which can cause embolic events such as stroke. Critical for implantable cardiovascular devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Thrombosis - device-related</rdfs:label>
        <rdfs:label xml:lang="ca">Trombosi relacionada amb el dispositiu</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SelfTestDeviceType -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SelfTestDeviceType">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType"/>
        <rdfs:comment xml:lang="en">Category of in vitro diagnostic devices that people can use at home, without medical staff, such as glucose monitors.</rdfs:comment>
        <rdfs:label xml:lang="en">Self-Test Device Type</rdfs:label>
        <rdfs:label xml:lang="ca">Tipus Dispositiu d&apos;Autodiagnòstic</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SingleUseDeviceType -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SingleUseDeviceType">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType"/>
        <rdfs:comment xml:lang="en">Category of medical devices used only once on a single patient, such as drug-eluting balloons or disposable instruments.</rdfs:comment>
        <rdfs:label xml:lang="en">Single-Use Device Type</rdfs:label>
        <rdfs:label xml:lang="ca">Tipus Dispositiu d&apos;un Sol Ús</rdfs:label>
    </owl:NamedIndividual>
    


