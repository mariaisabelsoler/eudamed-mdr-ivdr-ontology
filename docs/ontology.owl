    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableDeviceType -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableDeviceType">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType"/>
        <rdfs:comment xml:lang="en">Category of medical devices that are placed inside the human body and stay there after the procedure, such as joint replacements or heart valves.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device Type</rdfs:label>
        <rdfs:label xml:lang="ca">Tipus Dispositiu Implantable</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDeviceType -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDeviceType">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType"/>
        <rdfs:comment xml:lang="en">Category of medical devices used to analyse samples from the human body, such as blood, urine, or tissue.</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device Type</rdfs:label>
        <rdfs:label xml:lang="ca">Tipus Dispositiu de Diagnòstic In Vitro</rdfs:label>
    </owl:NamedIndividual>
    


