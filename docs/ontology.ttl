                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer> ;
                                                                                    rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country> ;
                                                                                    rdfs:comment "Connects a manufacturer to its country of registration."@en ;
                                                                                    rdfs:label "has country"@en ,
