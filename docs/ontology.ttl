                                                                                      rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass> ;
                                                                                      rdfs:comment "Connects a device to its regulatory risk class."@en ;
                                                                                      rdfs:label "has risk class"@en ,
                                                                                                 "té classe de risc"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/involvesDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/involvesDevice> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
