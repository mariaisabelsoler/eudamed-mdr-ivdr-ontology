###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :addressesIncident :INC-001 ;
          :countriesAffected :EUWide ;
          :status :Open ;
          :actionDate "2024-02-01"^^xsd:date ;
          :description "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :devicesAffected 850 ;
          :eudamedFscaRef "EU-FSCA-2024-000001" ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Safety alert issued by Medtronic in February 2024 to all centres implanting HeartMate 3 LVAD. The alert updates the anticoagulation protocol to reduce device thrombosis risk."@en ;
          rdfs:label "Alerta de Seguretat per anticoagulació HeartMate 3 LVAD"@ca ,
                     "Safety Alert for HeartMate 3 LVAD anticoagulation"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#FSCA-002
