                                                                                              "event date"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/imdrfCode
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/imdrfCode> rdf:type owl:DatatypeProperty ,
                                                                                            owl:FunctionalProperty ;
                                                                                   rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                   rdfs:range xsd:string ;
                                                                                   rdfs:comment "Code from the IMDRF (International Medical Device Regulators Forum) used to classify the risk."@en ;
                                                                                   rdfs:label "IMDRF code"@en ,
                                                                                              "codi IMDRF"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/intendedPurpose
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/intendedPurpose> rdf:type owl:DatatypeProperty ,
                                                                                                  owl:FunctionalProperty ;
                                                                                         rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                         rdfs:range xsd:string ;
                                                                                         rdfs:comment "The use for which the manufacturer designed the device."@en ;
                                                                                         rdfs:label "intended purpose"@en ,
                                                                                                    "ús previst"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isActive
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isActive> rdf:type owl:DatatypeProperty ,
                                                                                           owl:FunctionalProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                  rdfs:range xsd:boolean ;
                                                                                  rdfs:comment "True if the device needs an external energy source to work."@en ;
                                                                                  rdfs:label "is active"@en ,
                                                                                             "és actiu"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isImplantable
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isImplantable> rdf:type owl:DatatypeProperty ,
                                                                                                owl:FunctionalProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                       rdfs:range xsd:boolean ;
                                                                                       rdfs:comment "True if the device is implantable inside the human body."@en ;
                                                                                       rdfs:label "is implantable"@en ,
                                                                                                  "és implantable"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd> rdf:type owl:DatatypeProperty ;
                                                                               rdfs:subPropertyOf owl:topDataProperty ;
                                                                               rdf:type owl:FunctionalProperty ;
                                                                               rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                               rdfs:range xsd:boolean ;
                                                                               rdfs:comment "True if the device is for in vitro diagnostic use."@en ;
                                                                               rdfs:label "is IVD"@en ,
                                                                                          "és IVD"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isReusable
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isReusable> rdf:type owl:DatatypeProperty ,
                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                    rdfs:range xsd:boolean ;
                                                                                    rdfs:comment "True if the device can be used more than once."@en ;
                                                                                    rdfs:label "is reusable"@en ,
                                                                                               "és reutilitzable"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/outcome
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/outcome> rdf:type owl:DatatypeProperty ,
                                                                                          owl:FunctionalProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                 rdfs:range xsd:string ;
                                                                                 rdfs:comment "Description of what happened as a result of the incident."@en ;
                                                                                 rdfs:label "outcome"@en ,
                                                                                            "resultat"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientAge
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientAge> rdf:type owl:DatatypeProperty ,
                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                    rdfs:range xsd:integer ;
                                                                                    rdfs:comment "Age of the patient involved in the incident."@en ;
                                                                                    rdfs:label "edat del pacient"@ca ,
                                                                                               "patient age"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/reportDate
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/reportDate> rdf:type owl:DatatypeProperty ,
                                                                                             owl:FunctionalProperty ;
                                                                                    rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                    rdfs:range xsd:date ;
                                                                                    rdfs:comment "Date when the incident was reported."@en ;
                                                                                    rdfs:label "data de report"@ca ,
                                                                                               "report date"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/scope
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/scope> rdf:type owl:DatatypeProperty ,
                                                                                        owl:FunctionalProperty ;
                                                                               rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                               rdfs:range xsd:string ;
                                                                               rdfs:comment "Description of the scope of the corrective action, such as the affected lots or models."@en ;
                                                                               rdfs:label "abast"@ca ,
                                                                                          "scope"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/udiDi
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/udiDi> rdf:type owl:DatatypeProperty ,
                                                                                        owl:FunctionalProperty ;
                                                                               rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                               rdfs:range xsd:string ;
                                                                               rdfs:comment "Unique Device Identifier - Device Identifier. It is the unique code of a medical device under MDR."@en ;
                                                                               rdfs:label "UDI-DI"@ca ,
                                                                                          "UDI-DI"@en .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:DatatypeProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority>
                                                             <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer>
                                                             <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice>
                                                             <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk>
                                                           )
                                             ] ;
                                 rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://schema.org/Country
<http://schema.org/Country> rdf:type owl:Class .


###  http://schema.org/MedicalDevice
<http://schema.org/MedicalDevice> rdf:type owl:Class .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActionStatus> rdf:type owl:Class ;
                                                                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                            owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Closed>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open>
                                                                                                                      )
                                                                                                          ] ;
                                                                                      rdfs:comment "Status of a corrective action. The possible values are Open or Closed."@en ;
                                                                                      rdfs:label "Action Status"@en ,
                                                                                                 "Estat de l'Acció"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                      rdfs:comment "A medical device that needs an electrical source or another type of energy to work."@en ;
                                                                                      rdfs:label "Active Device"@en ,
                                                                                                 "Dispositiu Actiu"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority> rdf:type owl:Class ;
                                                                                            rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity> ;
                                                                                            rdfs:comment "The national authority in each EU country responsible for medical device regulation."@en ;
                                                                                            rdfs:label "Autoritat Competent"@ca ,
                                                                                                       "Competent Authority"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ContaminationRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ContaminationRisk> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                           rdfs:comment "Risk that the device or the patient gets contaminated."@en ;
                                                                                           rdfs:label "Contamination Risk"@en ,
                                                                                                      "Risc de Contaminació"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> rdf:type owl:Class ;
                                                                                          owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                                owl:oneOf ( :ActiveDeviceType
                                                                                                                            :ImplantableActiveDeviceType
                                                                                                                            :ImplantableDeviceType
                                                                                                                            :InVitroDiagnosticDeviceType
                                                                                                                            :SelfTestDeviceType
                                                                                                                            :SingleUseDeviceType
                                                                                                                          )
                                                                                                              ] ;
                                                                                          rdfs:comment "A Field Safety Corrective Action. It is any action a manufacturer takes to reduce a risk, such as a recall, a safety alert, or a user notice."@en ;
                                                                                          rdfs:label "Acció Correctiva (FSCA)"@ca ,
                                                                                                     "Corrective Action (FSCA)"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <http://schema.org/Country> ,
                                                                                                 <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope> ;
                                                                                 owl:disjointWith <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone> ;
                                                                                 rdfs:comment "A country, used to identify where manufacturers are registered or where incidents are reported."@en ;
                                                                                 rdfs:label "Country"@en ,
                                                                                            "País"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CybersecurityRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CybersecurityRisk> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                           rdfs:comment "Risk of unauthorized access or attacks on connected medical devices."@en ;
                                                                                           rdfs:label "Cybersecurity Risk"@en ,
                                                                                                      "Risc de Ciberseguretat"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticRisk> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                        rdfs:comment "Risk of wrong diagnostic results, such as false positives or false negatives."@en ;
                                                                                        rdfs:label "Diagnostic Risk"@en ,
                                                                                                   "Risc Diagnòstic"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope> rdf:type owl:Class ;
                                                                                         rdfs:comment "A general class for geographic areas. It includes both single countries and regulatory zones."@en ;
                                                                                         rdfs:label "Geographic Scope"@en ,
                                                                                                    "Àmbit Geogràfic"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDRRiskClass
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDRRiskClass> rdf:type owl:Class ;
                                                                                       owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                             owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassA>
                                                                                                                         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassB>
                                                                                                                         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassC>
                                                                                                                         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassD>
                                                                                                                       )
                                                                                                           ] ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass> ;
                                                                                       owl:disjointWith <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass> ;
                                                                                       rdfs:comment "Risk class for in vitro diagnostic devices under IVDR. The possible values are A, B, C, or D."@en ;
                                                                                       rdfs:label "Classe de Risc IVDR"@ca ,
                                                                                                  "IVDR Risk Class"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableActiveDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableActiveDevice> rdf:type owl:Class ;
                                                                                                 owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice>
                                                                                                                                            <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice>
                                                                                                                                          ) ;
                                                                                                                       rdf:type owl:Class
                                                                                                                     ] ;
                                                                                                 rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                                 rdfs:comment "A device that is both implantable and active. For example, a pacemaker."@en ;
                                                                                                 rdfs:label "Dispositiu Actiu Implantable"@ca ,
                                                                                                            "Implantable Active Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice> ;
                                                                                           owl:disjointWith <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice> ;
                                                                                           rdfs:comment "A medical device that is placed inside the human body and stays there after the procedure."@en ;
                                                                                           rdfs:label "Dispositiu Implantable"@ca ,
                                                                                                      "Implantable Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InSituCorrection
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InSituCorrection> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                          rdfs:comment "A corrective action done on devices that are already in use, without removing them from the market."@en ;
                                                                                          rdfs:label "Correcció In Situ"@ca ,
                                                                                                     "In-Situ Correction"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice> rdf:type owl:Class ;
                                                                                                 rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                                 rdfs:comment "A device used to analyse samples from the human body, such as blood or urine."@en ;
                                                                                                 rdfs:label "Dispositiu de Diagnòstic In Vitro"@ca ,
                                                                                                            "In Vitro Diagnostic Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> rdf:type owl:Class ;
                                                                                  rdfs:comment "An adverse event that happens with a medical device. Manufacturers must report incidents under MDR Article 87."@en ;
                                                                                  rdfs:label "Incident"@ca ,
                                                                                             "Incident"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InfectionRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InfectionRisk> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                       rdfs:comment "Risk of infection due to contamination or poor sterilization of the device."@en ;
                                                                                       rdfs:label "Infection Risk"@en ,
                                                                                                  "Risc d'Infecció"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                    rdfs:comment "Risk of physical harm to the patient caused by the device."@en ;
                                                                                    rdfs:label "Injury Risk"@en ,
                                                                                               "Risc de Lesió"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InterferenceRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InterferenceRisk> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                          rdfs:comment "Risk that the device gets disturbed by other devices, or that it disturbs other devices."@en ;
                                                                                          rdfs:label "Interference Risk"@en ,
                                                                                                     "Risc d'Interferència"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass> rdf:type owl:Class ;
                                                                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                            owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassI>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIa>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIb>
                                                                                                                      )
                                                                                                          ] ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass> ;
                                                                                      rdfs:comment "Risk class for devices under MDR. The possible values are I, IIa, IIb, or III."@en ;
                                                                                      rdfs:label "Classe de Risc MDR"@ca ,
                                                                                                 "MDR Risk Class"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MalfunctionRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MalfunctionRisk> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                         rdfs:comment "Risk that the device fails or stops working correctly."@en ;
                                                                                         rdfs:label "Malfunction Risk"@en ,
                                                                                                    "Risc de mal funcionament"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity> ;
                                                                                      rdfs:comment "A company or person that designs and produces medical devices. Manufacturers must register their devices in EUDAMED."@en ;
                                                                                      rdfs:label "Fabricant"@ca ,
                                                                                                 "Manufacturer"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MaterialRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MaterialRisk> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                      rdfs:comment "Risk caused by the materials used in the device, such as toxicity or wear."@en ;
                                                                                      rdfs:label "Material Risk"@en ,
                                                                                                 "Risc de Materials"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://schema.org/MedicalDevice> ;
                                                                                       rdfs:comment "A device used for medical purposes such as diagnosis, prevention, or treatment."@en ;
                                                                                       rdfs:label "Dispositiu Mèdic"@ca ,
                                                                                                  "Medical Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/NearMissIncident
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/NearMissIncident> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                          owl:disjointWith <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident> ;
                                                                                          rdfs:comment "An event that did not cause harm, but that could have been a serious incident."@en ;
                                                                                          rdfs:label "Near-Miss Incident"@en ,
                                                                                                     "Quasi-Incident"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Probability> rdf:type owl:Class ;
                                                                                     owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                           owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/High>
                                                                                                                       <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Low>
                                                                                                                       <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Medium>
                                                                                                                     )
                                                                                                         ] ;
                                                                                     rdfs:comment "How likely a risk is to happen. The possible values are Low, Medium, or High."@en ;
                                                                                     rdfs:label "Probabilitat"@ca ,
                                                                                                "Probability"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RadiationRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RadiationRisk> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                       rdfs:comment "Risk caused by radiation that comes from the device."@en ;
                                                                                       rdfs:label "Radiation Risk"@en ,
                                                                                                  "Risc de Radiació"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                rdfs:comment "A corrective action where the affected devices are removed from the market."@en ;
                                                                                rdfs:label "Recall"@en ,
                                                                                           "Retirada del Mercat"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryFramework> rdf:type owl:Class ;
                                                                                             owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                                   owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDR>
                                                                                                                               <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR>
                                                                                                                             )
                                                                                                                 ] ;
                                                                                             rdfs:comment "The European regulation that controls a medical device. It can be MDR or IVDR."@en ;
                                                                                             rdfs:label "Marc Regulatori"@ca ,
                                                                                                        "Regulatory Framework"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope> ;
                                                                                        rdfs:comment "A group of countries where a corrective action applies. For example, EU-wide or EU-wide plus UK."@en ;
                                                                                        rdfs:label "Regulatory Zone"@en ,
                                                                                                   "Zona Regulatòria"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ReportingEntity> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://xmlns.com/foaf/0.1/Agent> ;
                                                                                         rdfs:comment "An agent that can report medical device incidents. It can be a manufacturer, an authority, a healthcare professional, or a patient."@en ;
                                                                                         rdfs:label "Entitat Reportadora"@ca ,
                                                                                                    "Reporting Entity"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> rdf:type owl:Class ;
                                                                              rdfs:comment "A possible problem related to the use of a medical device. Each risk has a type, a category, a severity, and a probability."@en ;
                                                                              rdfs:label "Risc"@ca ,
                                                                                         "Risk"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory> rdf:type owl:Class ;
                                                                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                            owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceFailure>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DevicePerformance>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceSafety>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticError>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm>
                                                                                                                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality>
                                                                                                                      )
                                                                                                          ] ;
                                                                                      rdfs:comment "General classification of a risk. It can be device failure, patient harm, performance, safety, diagnostic error, or product quality."@en ;
                                                                                      rdfs:label "Categoria de Risc"@ca ,
                                                                                                 "Risk Category"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskClass> rdf:type owl:Class ;
                                                                                   rdfs:comment "Regulatory class of a medical device by risk level. It is defined by MDR (I, IIa, IIb, III) or by IVDR (A, B, C, D)."@en ;
                                                                                   rdfs:label "Classe de Risc"@ca ,
                                                                                              "Risk Class"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                     rdfs:comment "A message sent to users about a safety problem with a device."@en ;
                                                                                     rdfs:label "Alerta de Seguretat"@ca ,
                                                                                                "Safety Alert"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SelfTestDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SelfTestDevice> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InVitroDiagnosticDevice> ;
                                                                                        rdfs:comment "An in vitro diagnostic device that people can use at home, without medical staff."@en ;
                                                                                        rdfs:label "Dispositiu d'Autodiagnòstic"@ca ,
                                                                                                   "Self-Test Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                         rdfs:comment "An incident that caused or could cause death or serious health problems."@en ;
                                                                                         rdfs:label "Incident Greu"@ca ,
                                                                                                    "Serious Incident"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity> rdf:type owl:Class ;
                                                                                  owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                        owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Critical>
                                                                                                                    <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Moderate>
                                                                                                                    <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious>
                                                                                                                  )
                                                                                                      ] ;
                                                                                  rdfs:comment "Level of how serious a risk is. The possible values are Critical, Serious, or Moderate."@en ;
                                                                                  rdfs:label "Gravetat"@ca ,
                                                                                             "Severity"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Sex> rdf:type owl:Class ;
                                                                             owl:equivalentClass [ rdf:type owl:Class ;
                                                                                                   owl:oneOf ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Female>
                                                                                                               <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Male>
                                                                                                             )
                                                                                                 ] ;
                                                                             rdfs:comment "Sex of a patient involved in an incident. The possible values are Male or Female."@en ;
                                                                             rdfs:label "Sex"@en ,
                                                                                        "Sexe"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SingleUseDevice> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                         rdfs:comment "A medical device used only once on a single patient. Implantable devices are also single-use."@en ;
                                                                                         rdfs:label "Dispositiu d'un Sol Ús"@ca ,
                                                                                                    "Single-Use Device"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SoftwareRisk
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SoftwareRisk> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                      rdfs:comment "Risk caused by errors or bugs in the device software."@en ;
                                                                                      rdfs:label "Risc de Programari"@ca ,
                                                                                                 "Software Risk"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/UserNotice
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/UserNotice> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                    rdfs:comment "A notice sent to users with instructions on how to use or limit the device."@en ;
                                                                                    rdfs:label "Avís a Usuaris"@ca ,
                                                                                               "User Notice"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType
:MedicalDeviceType rdf:type owl:Class ;
                   rdfs:comment "Closed enumeration of device type categories used to classify which devices a risk affects."@en ;
                   rdfs:label "Medical Device Type"@en ,
                              "Tipus de Dispositius mèdics"@ca .


