                   :Recall ;
          :addressesIncident :INC-001 ;
          :actionDate "2024-02-28"^^xsd:date ;
          :closureDate "2024-05-31"^^xsd:date ;
          :devicesAffected 1240 ;
          :eudamedFscaRef "EU-FSCA-2024-000002" ;
          :scope "Micra AV lots manufactured between 2022-09 and 2023-03" ;
          rdfs:comment "Voluntary recall of Micra AV pacemaker units affected by premature battery depletion. The action was opened in February 2024 and closed in May 2024 after replacement of all affected devices."@en ;
          rdfs:label "FSCA-002 Micra AV pacemaker recall"@en .


