                                                                                                  owl:FunctionalProperty ;
                                                                                         rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                         rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country> ;
                                                                                         rdfs:comment "Country where the incident was reported."@en ;
                                                                                         rdfs:label "country reported"@en ,
                                                                                                    "país on s'ha reportat"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCompetentAuthority
