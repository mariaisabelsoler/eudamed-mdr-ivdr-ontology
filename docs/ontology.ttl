###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm> rdf:type owl:NamedIndividual ,
                                                                                              <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory> ;
                                                                                     rdfs:comment "Risk category related to physical harm to the patient."@en ;
                                                                                     rdfs:label "Dany al Pacient"@ca ,
                                                                                                "Patient Harm"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality> rdf:type owl:NamedIndividual ,
                                                                                                 <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory> ;
                                                                                        rdfs:comment "Risk category related to the quality of the product."@en ;
                                                                                        rdfs:label "Product Quality"@en ,
                                                                                                   "Qualitat del Producte"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious> rdf:type owl:NamedIndividual ,
                                                                                          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity> ;
                                                                                 rdfs:comment "Serious level of severity. The risk can cause important harm to the patient."@en ;
                                                                                 rdfs:label "Greu"@ca ,
                                                                                            "Serious"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ActiveDeviceType
:ActiveDeviceType rdf:type owl:NamedIndividual ,
                           :MedicalDeviceType ;
                  rdfs:comment "Category of medical devices that need an external energy source to work, such as imaging or monitoring equipment."@en ;
                  rdfs:label "Active Device Type"@en ,
                             "Tipus Dispositiu Actiu"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ActiveDevice> ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ImplantableDevice> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasManufacturer> :MAN-001 ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRegulatoryFramework> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRiskClass> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/intendedPurpose> "Ventricular assist device for end-stage heart failure" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isActive> "true"^^xsd:boolean ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isImplantable> "true"^^xsd:boolean ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd> "false"^^xsd:boolean ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isReusable> "false"^^xsd:boolean ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/udiDi> "(01)00380740009095" ;
         <http://xmlns.com/foaf/0.1/name> "HeartMate 3 LVAD" ;
         rdfs:comment "Left ventricular assist device used for end-stage heart failure. It is a centrifugal-flow pump that supports cardiac function in patients waiting for a heart transplant or as a long-term solution."@en ;
         rdfs:label "HeartMate 3 LVAD"@ca ,
                    "HeartMate 3 LVAD"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#EUWide
:EUWide rdf:type owl:NamedIndividual ,
                 <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RegulatoryZone> ;
        rdfs:comment "Regulatory zone covering all the European Union member states."@en ;
        rdfs:label "EU-wide"@en ,
                   "Tota la UE"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert> ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/addressesIncident> :INC-001 ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countriesAffected> :EUWide ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/status> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open> ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/actionDate> "2024-02-01"^^xsd:date ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/description> "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/devicesAffected> 850 ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedFscaRef> "EU-FSCA-2024-000001" ;
          <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/scope> "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Safety alert issued by Medtronic in February 2024 to all centres implanting HeartMate 3 LVAD. The alert updates the anticoagulation protocol to reduce device thrombosis risk."@en ;
          rdfs:label "Alerta de Seguretat per anticoagulació HeartMate 3 LVAD"@ca ,
                     "Safety Alert for HeartMate 3 LVAD anticoagulation"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Germany
:Germany rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country> ;
         rdfs:comment "Country in Central Europe. Member State of the European Union."@en ;
         rdfs:label "Alemanya"@ca ,
                    "Germany"@en ;
         owl:sameAs "http://dbpedia.org/resource/Germany" .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#HPRA
:HPRA rdf:type owl:NamedIndividual ,
               <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CompetentAuthority> ;
      rdfs:comment "The Health Products Regulatory Authority is the competent authority for medical devices in Ireland."@en ;
      rdfs:label "Autoritat Reguladora de Productes (HPRA)"@ca ,
                 "Health Products Regulatory Authority (HPRA)"@en ;
      owl:sameAs "http://dbpedia.org/resource/Health_Products_Regulatory_Authority" .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#INC-001
:INC-001 rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SeriousIncident> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countryReported> :Germany ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasReportingEntity> :MAN-001 ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/involvesDevice> :DEV-001 ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/materializesRisk> :RSK-003 ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientSex> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Male> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/correctiveActionTaken> "true"^^xsd:boolean ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/description> "Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant. Device thrombus confirmed by echocardiography." ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/detectionDate> "2024-01-10"^^xsd:date ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedIncidentRef> "EU-INC-2024-000001" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eventDate> "2024-01-08"^^xsd:date ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/outcome> "Serious patient injury - embolic stroke" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/patientAge> 58 ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/reportDate> "2024-01-15"^^xsd:date ;
         rdfs:comment "Serious incident reported in Germany in January 2024. A patient implanted with a HeartMate 3 LVAD developed an ischemic stroke six months after implantation. Device thrombus was confirmed by echocardiography."@en ;
         rdfs:label "Incident d'ictus amb HeartMate 3 LVAD."@ca ,
                    "Stroke incident with HeartMate 3 LVAD."@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableActiveDeviceType
:ImplantableActiveDeviceType rdf:type owl:NamedIndividual ,
                                      :MedicalDeviceType ;
                             rdfs:comment "Category of medical devices that are both implantable and active, such as pacemakers or ventricular assist devices."@en ;
                             rdfs:label "Implantable Active Device Type"@en ,
                                        "Tipus Dispositiu Actiu Implantable"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableDeviceType
:ImplantableDeviceType rdf:type owl:NamedIndividual ,
                                :MedicalDeviceType ;
                       rdfs:comment "Category of medical devices that are placed inside the human body and stay there after the procedure, such as joint replacements or heart valves."@en ;
                       rdfs:label "Implantable Device Type"@en ,
                                  "Tipus Dispositiu Implantable"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDeviceType
:InVitroDiagnosticDeviceType rdf:type owl:NamedIndividual ,
                                      :MedicalDeviceType ;
                             rdfs:comment "Category of medical devices used to analyse samples from the human body, such as blood, urine, or tissue."@en ;
                             rdfs:label "In Vitro Diagnostic Device Type"@en ,
                                        "Tipus Dispositiu de Diagnòstic In Vitro"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Ireland
:Ireland rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Country> ;
         rdfs:comment "Country in Western Europe. Member State of the European Union."@en ;
         rdfs:label "Ireland"@en ,
                    "Irlanda"@ca ;
         owl:sameAs "http://dbpedia.org/resource/Ireland" .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MAN-001
:MAN-001 rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Manufacturer> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCompetentAuthority> :HPRA ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasCountry> :Ireland ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/authorizationNumber> "IE/2017/001234" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/contactEmail> "regulatory@medtronic.com" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/eudamedSrn> "SRN-IE-MED-0001" ;
         <http://xmlns.com/foaf/0.1/name> "Medtronic plc" ;
         rdfs:comment "Irish-American medical device company headquartered in Dublin. One of the largest medical device manufacturers in the world."@en ;
         rdfs:label "Medtronic plc"@ca ,
                    "Medtronic plc"@en ;
         owl:sameAs "http://dbpedia.org/resource/Medtronic" .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RSK-003
:RSK-003 rdf:type owl:NamedIndividual ,
                  <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InjuryRisk> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/affectedDeviceType> :ImplantableActiveDeviceType ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/category> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/probability> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Low> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/severity> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Critical> ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/description> "Thrombus formation on device surface causing embolic events" ;
         <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/imdrfCode> "A0201" ;
         <http://xmlns.com/foaf/0.1/name> "Thrombosis - device-related" ;
         rdfs:comment "Risk of thrombus formation on the device surface, which can cause embolic events such as stroke. Critical for implantable cardiovascular devices."@en ;
         rdfs:label "Thrombosis - device-related"@en ,
                    "Trombosi relacionada amb el dispositiu"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SelfTestDeviceType
:SelfTestDeviceType rdf:type owl:NamedIndividual ,
                             :MedicalDeviceType ;
                    rdfs:comment "Category of in vitro diagnostic devices that people can use at home, without medical staff, such as glucose monitors."@en ;
                    rdfs:label "Self-Test Device Type"@en ,
                               "Tipus Dispositiu d'Autodiagnòstic"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SingleUseDeviceType
:SingleUseDeviceType rdf:type owl:NamedIndividual ,
                              :MedicalDeviceType ;
                     rdfs:comment "Category of medical devices used only once on a single patient, such as drug-eluting balloons or disposable instruments."@en ;
                     rdfs:label "Single-Use Device Type"@en ,
                                "Tipus Dispositiu d'un Sol Ús"@ca .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/InSituCorrection>
                <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Recall>
                <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/SafetyAlert>
                <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/UserNotice>
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassA>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassB>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassC>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassD>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassI>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIa>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIb>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Closed>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Open>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Critical>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Moderate>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Serious>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceFailure>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DevicePerformance>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DeviceSafety>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/DiagnosticError>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/PatientHarm>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ProductQuality>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Female>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Male>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/High>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Low>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Medium>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/IVDR>
                        <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR>
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :ActiveDeviceType
                        :ImplantableActiveDeviceType
                        :ImplantableDeviceType
                        :InVitroDiagnosticDeviceType
                        :SelfTestDeviceType
                        :SingleUseDeviceType
                      )
] .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#a> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#date> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdfs:comment "Marks a corrective action as Closed when it has a closure date."@en ;
   rdfs:label "CorrectiveAction Status by closureDate"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/closureDate> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#date>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/status> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Closed>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment "Assigns MDR regulatory framework to devices that are not in vitro diagnostic."@en ;
   rdfs:label "MedicalDevice RegulatoryFramework by isIvd"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/isIvd> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> "false"^^xsd:boolean
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/hasRegulatoryFramework> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDR>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment "Classifies a device as SingleUseDevice when isReusable is false."@en ;
   rdfs:label "MedicalDevice Type by isReusable"@en ;
