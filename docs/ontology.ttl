@prefix : <http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#> .

<http://www.uoc.edu/ontologies/eudamed-mdr-ivdr> rdf:type owl:Ontology ;
                                                  owl:versionIRI <http://www.uoc.edu/ontologies/eudamed-mdr-ivdr/1.0.0> ;
                                                  <http://purl.org/dc/elements/1.1/creator> "Maria Isabel Soler"@en ;
                                                  <http://purl.org/dc/elements/1.1/description> "The purpose of the ontology is to model the domain of medical devices and in vitro diagnostic devices registered in the European EUDAMED database, including manufacturers, identified risks, incidents, and field safety corrective actions (FSCAs). The goal is to enable the different information systems in the sector — manufacturers, regulatory authorities, hospitals, and patients — to share data accurately, without ambiguity, and to interoperate easily with each other."@en ;
                                                  <http://purl.org/dc/elements/1.1/source> "EUDAMED public repository, https://ec.europa.eu/tools/eudamed/"@en ;
                                                  <http://purl.org/dc/elements/1.1/title> "EUDAMED MDR-IVDR Ontology"@en ;
                                                  <http://purl.org/dc/terms/bibliographicCitation> "Soler, Maria Isabel (2026). EUDAMED MDR-IVDR Ontology. Universitat Oberta de Catalunya (UOC)."@en ;
                                                  <http://purl.org/dc/terms/created> "2026-04-26"^^xsd:date ;
                                                  <http://purl.org/dc/terms/issued> "2026-04-27"^^xsd:date ;
                                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                  <http://purl.org/dc/terms/publisher> "Universitat Oberta de Catalunya (UOC)"@en ;
                                                  <http://purl.org/ontology/bibo/status> <http://purl.org/ontology/bibo/status/draft> ;
                                                  <http://purl.org/vocab/vann/preferredNamespacePrefix> "eudamed" ;
                                                  <http://purl.org/vocab/vann/preferredNamespaceUri> "http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#" ;
                                                  rdfs:label "EUDAMED MDR-IVDR Ontology"@en ,
                                                             "eudamed" ;
                                                  owl:versionInfo "1.0.0" ;
                                                  <http://xmlns.com/foaf/0.1/logo> <https://upload.wikimedia.org/wikipedia/commons/7/79/Logotipo_UOC.svg> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty ;
                                          rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty ;
                                              rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/elements/1.1/source
<http://purl.org/dc/elements/1.1/source> rdf:type owl:AnnotationProperty ;
                                         rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty ;
                                        rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty ;
                                                 rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty ;
                                   rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty ;
                                  rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty ;
                                   rdfs:subPropertyOf rdfs:label .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty ;
                                     rdfs:subPropertyOf rdfs:label .


###  http://purl.org/ontology/bibo/status
<http://purl.org/ontology/bibo/status> rdf:type owl:AnnotationProperty ;
                                       rdfs:subPropertyOf rdfs:label .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty ;
                                                      rdfs:subPropertyOf rdfs:label .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty ;
                                                   rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf rdfs:label .


###  http://xmlns.com/foaf/0.1/logo
<http://xmlns.com/foaf/0.1/logo> rdf:type owl:AnnotationProperty ;
                                 rdfs:subPropertyOf rdfs:label .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range :Incident ;
                   rdfs:comment "Connects a corrective action to the incident that it addresses."@en ;
                   rdfs:label "addresses incident"@en ,
                              "tracta l'incident"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#affectedDeviceType
:affectedDeviceType rdf:type owl:ObjectProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :MedicalDevice ;
                    rdfs:comment "Connects a risk to the types of medical devices that it can affect."@en ;
                    rdfs:label "affected device type"@en ,
                               "tipus de dispositiu afectat"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#category
:category rdf:type owl:ObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range :RiskCategory ;
          rdfs:comment "Connects a risk to its general category."@en ;
          rdfs:label "categoria"@ca ,
                     "category"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#countriesAffected
:countriesAffected rdf:type owl:ObjectProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range :GeographicScope ;
                   rdfs:comment "Geographic area affected by a corrective action. It can be a single country or a regulatory zone."@en ;
                   rdfs:label "countries affected"@en ,
                              "països afectats"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#countryReported
:countryReported rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :Country ;
                 rdfs:comment "Country where the incident was reported."@en ;
                 rdfs:label "country reported"@en ,
                            "país on s'ha reportat"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasCompetentAuthority
:hasCompetentAuthority rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Manufacturer ;
                       rdfs:range :CompetentAuthority ;
                       rdfs:comment "Connects a manufacturer to its competent authority."@en ;
                       rdfs:label "has competent authority"@en ,
                                  "té autoritat competent"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasCountry
:hasCountry rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range :Country ;
            rdfs:comment "Connects a manufacturer to its country of registration."@en ;
            rdfs:label "has country"@en ,
                       "té país"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :MedicalDevice ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Connects a medical device to its manufacturer."@en ;
                 rdfs:label "has manufacturer"@en ,
                            "té fabricant"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain :MedicalDevice ;
                        rdfs:range :RegulatoryFramework ;
                        rdfs:comment "Indicates the EU regulation that applies to a device. It can be MDR or IVDR."@en ;
                        rdfs:label "has regulatory framework"@en ,
                                   "té marc regulatori"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasReportingEntity
:hasReportingEntity rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range :ReportingEntity ;
                    rdfs:comment "Connects an incident to the entity that reported it."@en ;
                    rdfs:label "has reporting entity"@en ,
                               "té entitat reportadora"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain :MedicalDevice ;
              rdfs:range :RiskClass ;
              rdfs:comment "Connects a device to its regulatory risk class."@en ;
              rdfs:label "has risk class"@en ,
                         "té classe de risc"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :MedicalDevice ;
                rdfs:comment "Connects an incident to the medical device involved."@en ;
                rdfs:label "involucra dispositiu"@ca ,
                           "involves device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#materializesRisk
:materializesRisk rdf:type owl:ObjectProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range :Risk ;
                  rdfs:comment "Connects an incident to the risks that happened in it."@en ;
                  rdfs:label "materialitza risc"@ca ,
                             "materializes risk"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#patientSex
:patientSex rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Sex ;
            rdfs:comment "Indicates the sex of the patient involved in the incident."@en ;
            rdfs:label "patient sex"@en ,
                       "sexe del pacient"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#probability
:probability rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Risk ;
             rdfs:range :Probability ;
             rdfs:comment "Connects a risk to its probability level."@en ;
             rdfs:label "probabilitat"@ca ,
                        "probability"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#severity
:severity rdf:type owl:ObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range :Severity ;
          rdfs:comment "Connects a risk to its severity level."@en ;
          rdfs:label "gravetat"@ca ,
                     "severity"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#status
:status rdf:type owl:ObjectProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :CorrectiveAction ;
        rdfs:range :ActionStatus ;
        rdfs:comment "Current status of a corrective action. It can be Open or Closed."@en ;
        rdfs:label "estat"@ca ,
                   "status"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#actionDate
:actionDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :CorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "Date when the corrective action started."@en ;
            rdfs:label "action date"@en ,
                       "data de l'acció"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Authorization number assigned to a manufacturer."@en ;
                     rdfs:label "authorization number"@en ,
                                "número d'autorització"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#closureDate
:closureDate rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "Date when the corrective action was closed."@en ;
             rdfs:label "closure date"@en ,
                        "data de tancament"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Email address used to contact the manufacturer."@en ;
              rdfs:label "contact email"@en ,
                         "correu de contacte"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "True if a corrective action was taken after the incident."@en ;
                       rdfs:label "acció correctiva realitzada"@ca ,
                                  "corrective action taken"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#description
:description rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :CorrectiveAction
                                         :Incident
                                         :Risk
                                       )
                         ] ;
             rdfs:range xsd:string ;
             rdfs:comment "Text description of the entity, such as a risk, an incident, or a corrective action."@en ;
             rdfs:label "descripció"@ca ,
                        "description"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date when the incident was detected."@en ;
               rdfs:label "data de detecció"@ca ,
                          "detection date"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Number of devices affected by the corrective action."@en ;
                 rdfs:label "devices affected"@en ,
                            "dispositius afectats"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#eudamedFscaRef
:eudamedFscaRef rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "Reference number of the corrective action in EUDAMED."@en ;
                rdfs:label "EUDAMED FSCA reference"@en ,
                           "referència FSCA a EUDAMED"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Reference number of the incident in EUDAMED."@en ;
                    rdfs:label "EUDAMED incident reference"@en ,
                               "referència d'incident a EUDAMED"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#eudamedSrn
:eudamedSrn rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "Single Registration Number of the manufacturer in EUDAMED."@en ;
            rdfs:label "EUDAMED SRN"@en ,
                       "SRN d'EUDAMED"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#eventDate
:eventDate rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "Date when the incident happened."@en ;
           rdfs:label "data de l'esdeveniment"@ca ,
                      "event date"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "Code from the IMDRF (International Medical Device Regulators Forum) used to classify the risk."@en ;
           rdfs:label "IMDRF code"@en ,
                      "codi IMDRF"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :MedicalDevice ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The use for which the manufacturer designed the device."@en ;
                 rdfs:label "intended purpose"@en ,
                            "ús previst"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#isActive
:isActive rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean ;
          rdfs:comment "True if the device needs an external energy source to work."@en ;
          rdfs:label "is active"@en ,
                     "és actiu"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:boolean ;
               rdfs:comment "True if the device is implantable inside the human body."@en ;
               rdfs:label "is implantable"@en ,
                          "és implantable"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#isIvd
:isIvd rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdf:type owl:FunctionalProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:boolean ;
       rdfs:comment "True if the device is for in vitro diagnostic use."@en ;
       rdfs:label "is IVD"@en ,
                  "és IVD"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#isReusable
:isReusable rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:boolean ;
            rdfs:comment "True if the device can be used more than once."@en ;
            rdfs:label "is reusable"@en ,
                       "és reutilitzable"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#outcome
:outcome rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Description of what happened as a result of the incident."@en ;
         rdfs:label "outcome"@en ,
                    "resultat"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#patientAge
:patientAge rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "Age of the patient involved in the incident."@en ;
            rdfs:label "edat del pacient"@ca ,
                       "patient age"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#reportDate
:reportDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Date when the incident was reported."@en ;
            rdfs:label "data de report"@ca ,
                       "report date"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#scope
:scope rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :CorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "Description of the scope of the corrective action, such as the affected lots or models."@en ;
       rdfs:label "abast"@ca ,
                  "scope"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#udiDi
:udiDi rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:string ;
       rdfs:comment "Unique Device Identifier - Device Identifier. It is the unique code of a medical device under MDR."@en ;
       rdfs:label "UDI-DI"@ca ,
                  "UDI-DI"@en .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:DatatypeProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( :CompetentAuthority
                                                             :Manufacturer
                                                             :MedicalDevice
                                                             :Risk
                                                           )
                                             ] ;
                                 rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://schema.org/Country
<http://schema.org/Country> rdf:type owl:Class .


###  http://schema.org/MedicalDevice
<http://schema.org/MedicalDevice> rdf:type owl:Class .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ActionStatus
:ActionStatus rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :Closed
                                                :Open
                                              )
                                  ] ;
              rdfs:comment "Status of a corrective action. The possible values are Open or Closed."@en ;
              rdfs:label "Action Status"@en ,
                         "Estat de l'Acció"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "A medical device that needs an electrical source or another type of energy to work."@en ;
              rdfs:label "Active Device"@en ,
                         "Dispositiu Actiu"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:subClassOf :ReportingEntity ;
                    rdfs:comment "The national authority in each EU country responsible for medical device regulation."@en ;
                    rdfs:label "Autoritat Competent"@ca ,
                               "Competent Authority"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk that the device or the patient gets contaminated."@en ;
                   rdfs:label "Contamination Risk"@en ,
                              "Risc de Contaminació"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :addressesIncident ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :Incident
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :status ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :ActionStatus
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :actionDate ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :description ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :devicesAffected ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :eudamedFscaRef ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :scope ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ;
                  rdfs:comment "A Field Safety Corrective Action. It is any action a manufacturer takes to reduce a risk, such as a recall, a safety alert, or a user notice."@en ;
                  rdfs:label "Acció Correctiva (FSCA)"@ca ,
                             "Corrective Action (FSCA)"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf <http://schema.org/Country> ,
                         :GeographicScope ;
         owl:disjointWith :RegulatoryZone ;
         rdfs:comment "A country, used to identify where manufacturers are registered or where incidents are reported."@en ;
         rdfs:label "Country"@en ,
                    "País"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk of unauthorized access or attacks on connected medical devices."@en ;
                   rdfs:label "Cybersecurity Risk"@en ,
                              "Risc de Ciberseguretat"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk of wrong diagnostic results, such as false positives or false negatives."@en ;
                rdfs:label "Diagnostic Risk"@en ,
                           "Risc Diagnòstic"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#GeographicScope
:GeographicScope rdf:type owl:Class ;
                 rdfs:comment "A general class for geographic areas. It includes both single countries and regulatory zones."@en ;
                 rdfs:label "Geographic Scope"@en ,
                            "Àmbit Geogràfic"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#IVDRRiskClass
:IVDRRiskClass rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :ClassA
                                                 :ClassB
                                                 :ClassC
                                                 :ClassD
                                               )
                                   ] ;
               rdfs:subClassOf :RiskClass ;
               owl:disjointWith :MDRRiskClass ;
               rdfs:comment "Risk class for in vitro diagnostic devices under IVDR. The possible values are A, B, C, or D."@en ;
               rdfs:label "Classe de Risc IVDR"@ca ,
                          "IVDR Risk Class"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :ActiveDevice
                                                                    :ImplantableDevice
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A device that is both implantable and active. For example, a pacemaker."@en ;
                         rdfs:label "Dispositiu Actiu Implantable"@ca ,
                                    "Implantable Active Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :SingleUseDevice ;
                   owl:disjointWith :InVitroDiagnosticDevice ;
                   rdfs:comment "A medical device that is placed inside the human body and stays there after the procedure."@en ;
                   rdfs:label "Dispositiu Implantable"@ca ,
                              "Implantable Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "A corrective action done on devices that are already in use, without removing them from the market."@en ;
                  rdfs:label "Correcció In Situ"@ca ,
                             "In-Situ Correction"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A device used to analyse samples from the human body, such as blood or urine."@en ;
                         rdfs:label "Dispositiu de Diagnòstic In Vitro"@ca ,
                                    "In Vitro Diagnostic Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :countryReported ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Country
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasReportingEntity ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :ReportingEntity
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesDevice ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :MedicalDevice
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :correctiveActionTaken ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:boolean
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :description ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :detectionDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eudamedIncidentRef ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eventDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ;
          rdfs:comment "An adverse event that happens with a medical device."@en ;
          rdfs:label "Incident"@ca ,
                     "Incident"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of infection due to contamination or poor sterilization of the device."@en ;
               rdfs:label "Infection Risk"@en ,
                          "Risc d'Infecció"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk of physical harm to the patient caused by the device."@en ;
            rdfs:label "Injury Risk"@en ,
                       "Risc de Lesió"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "Risk that the device gets disturbed by other devices, or that it disturbs other devices."@en ;
                  rdfs:label "Interference Risk"@en ,
                             "Risc d'Interferència"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MDRRiskClass
:MDRRiskClass rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :ClassI
                                                :ClassIII
                                                :ClassIIa
                                                :ClassIIb
                                              )
                                  ] ;
              rdfs:subClassOf :RiskClass ;
              rdfs:comment "Risk class for devices under MDR. The possible values are I, IIa, IIb, or III."@en ;
              rdfs:label "Classe de Risc MDR"@ca ,
                         "MDR Risk Class"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk that the device fails or stops working correctly."@en ;
                 rdfs:label "Malfunction Risk"@en ,
                            "Risc de mal funcionament"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :ReportingEntity ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCompetentAuthority ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :CompetentAuthority
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCountry ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :Country
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :authorizationNumber ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :contactEmail ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamedSrn ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://xmlns.com/foaf/0.1/name> ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "A company or person that designs and produces medical devices. Manufacturers must register their devices in EUDAMED."@en ;
              rdfs:label "Fabricant"@ca ,
                         "Manufacturer"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk caused by the materials used in the device, such as toxicity or wear."@en ;
              rdfs:label "Material Risk"@en ,
                         "Risc de Materials"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf <http://schema.org/MedicalDevice> ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasManufacturer ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Manufacturer
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasRiskClass ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :RiskClass
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :intendedPurpose ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isActive ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:boolean
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isImplantable ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:boolean
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isIvd ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:boolean
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isReusable ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:boolean
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :udiDi ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:string
                               ] ;
               rdfs:comment "A device used for medical purposes such as diagnosis, prevention, or treatment."@en ;
               rdfs:label "Dispositiu Mèdic"@ca ,
                          "Medical Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#MedicalDeviceType
:MedicalDeviceType rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:oneOf ( :ActiveDeviceType
                                                     :ImplantableActiveDeviceType
                                                     :ImplantableDeviceType
                                                     :InVitroDiagnosticDeviceType
                                                     :SelfTestDeviceType
                                                     :SingleUseDeviceType
                                                   )
                                       ] ;
                   rdfs:comment "Closed enumeration of device type categories used to classify which devices a risk affects."@en ;
                   rdfs:label "Medical Device Type"@en ,
                              "Tipus de Dispositius mèdics"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  owl:disjointWith :SeriousIncident ;
                  rdfs:comment "An event that did not cause harm, but that could have been a serious incident."@en ;
                  rdfs:label "Near-Miss Incident"@en ,
                             "Quasi-Incident"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Probability
:Probability rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Class ;
                                   owl:oneOf ( :High
                                               :Low
                                               :Medium
                                             )
                                 ] ;
             rdfs:comment "How likely a risk is to happen. The possible values are Low, Medium, or High."@en ;
             rdfs:label "Probabilitat"@ca ,
                        "Probability"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk caused by radiation that comes from the device."@en ;
               rdfs:label "Radiation Risk"@en ,
                          "Risc de Radiació"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "A corrective action where the affected devices are removed from the market."@en ;
        rdfs:label "Recall"@en ,
                   "Retirada del Mercat"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     owl:equivalentClass [ rdf:type owl:Class ;
                                           owl:oneOf ( :IVDR
                                                       :MDR
                                                     )
                                         ] ;
                     rdfs:comment "The European regulation that controls a medical device. It can be MDR or IVDR."@en ;
                     rdfs:label "Marc Regulatori"@ca ,
                                "Regulatory Framework"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RegulatoryZone
:RegulatoryZone rdf:type owl:Class ;
                rdfs:subClassOf :GeographicScope ;
                rdfs:comment "A group of countries where a corrective action applies. For example, EU-wide or EU-wide plus UK."@en ;
                rdfs:label "Regulatory Zone"@en ,
                           "Zona Regulatòria"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ReportingEntity
:ReportingEntity rdf:type owl:Class ;
                 rdfs:subClassOf <http://xmlns.com/foaf/0.1/Agent> ;
                 rdfs:comment "An agent that can report medical device incidents. It can be a manufacturer, an authority, a healthcare professional, or a patient."@en ;
                 rdfs:label "Entitat Reportadora"@ca ,
                            "Reporting Entity"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :category ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :RiskCategory
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :probability ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Probability
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :severity ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Severity
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :description ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrfCode ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty <http://xmlns.com/foaf/0.1/name> ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "A possible problem related to the use of a medical device. Each risk has a type, a category, a severity, and a probability."@en ;
      rdfs:label "Risc"@ca ,
                 "Risk"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RiskCategory
:RiskCategory rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :DeviceFailure
                                                :DevicePerformance
                                                :DeviceSafety
                                                :DiagnosticError
                                                :PatientHarm
                                                :ProductQuality
                                              )
                                  ] ;
              rdfs:comment "General classification of a risk. It can be device failure, patient harm, performance, safety, diagnostic error, or product quality."@en ;
              rdfs:label "Categoria de Risc"@ca ,
                         "Risk Category"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Regulatory class of a medical device by risk level. It is defined by MDR (I, IIa, IIb, III) or by IVDR (A, B, C, D)."@en ;
           rdfs:label "Classe de Risc"@ca ,
                      "Risk Class"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction ;
             rdfs:comment "A message sent to users about a safety problem with a device."@en ;
             rdfs:label "Alerta de Seguretat"@ca ,
                        "Safety Alert"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :InVitroDiagnosticDevice ;
                rdfs:comment "An in vitro diagnostic device that people can use at home, without medical staff."@en ;
                rdfs:label "Dispositiu d'Autodiagnòstic"@ca ,
                           "Self-Test Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that caused or could cause death or serious health problems."@en ;
                 rdfs:label "Incident Greu"@ca ,
                            "Serious Incident"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Severity
:Severity rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Class ;
                                owl:oneOf ( :Critical
                                            :Moderate
                                            :Serious
                                          )
                              ] ;
          rdfs:comment "Level of how serious a risk is. The possible values are Critical, Serious, or Moderate."@en ;
          rdfs:label "Gravetat"@ca ,
                     "Severity"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Sex
:Sex rdf:type owl:Class ;
     owl:equivalentClass [ rdf:type owl:Class ;
                           owl:oneOf ( :Female
                                       :Male
                                     )
                         ] ;
     rdfs:comment "Sex of a patient involved in an incident. The possible values are Male or Female."@en ;
     rdfs:label "Sex"@en ,
                "Sexe"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :MedicalDevice ;
                 rdfs:comment "A medical device used only once on a single patient. Implantable devices are also single-use."@en ;
                 rdfs:label "Dispositiu d'un Sol Ús"@ca ,
                            "Single-Use Device"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk caused by errors or bugs in the device software."@en ;
              rdfs:label "Risc de Programari"@ca ,
                         "Software Risk"@en .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction ;
            rdfs:comment "A notice sent to users with instructions on how to use or limit the device."@en ;
            rdfs:label "Avís a Usuaris"@ca ,
                       "User Notice"@en .


###  http://xmlns.com/foaf/0.1/Agent
<http://xmlns.com/foaf/0.1/Agent> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ActiveDeviceType
:ActiveDeviceType rdf:type owl:NamedIndividual ,
                           :MedicalDeviceType ;
                  rdfs:comment "Category of medical devices that need an external energy source to work, such as imaging or monitoring equipment."@en ;
                  rdfs:label "Active Device Type"@en ,
                             "Tipus Dispositiu Actiu"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassA
:ClassA rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
        rdfs:comment "IVDR risk class A. Lowest risk for in vitro diagnostic devices."@en ;
        rdfs:label "Class A"@en ,
                   "Classe A"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassB
:ClassB rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
        rdfs:comment "IVDR risk class B. Low to moderate risk for in vitro diagnostic devices."@en ;
        rdfs:label "Class B"@en ,
                   "Classe B"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassC
:ClassC rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
        rdfs:comment "IVDR risk class C. Moderate to high risk for in vitro diagnostic devices."@en ;
        rdfs:label "Class C"@en ,
                   "Classe C"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassD
:ClassD rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
        rdfs:comment "IVDR risk class D. Highest risk for in vitro diagnostic devices."@en ;
        rdfs:label "Class D"@en ,
                   "Classe D"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassI
:ClassI rdf:type owl:NamedIndividual ,
                 :MDRRiskClass ;
        rdfs:comment "MDR risk class I. Lowest risk for medical devices."@en ;
        rdfs:label "Class I"@en ,
                   "Classe I"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassIII
:ClassIII rdf:type owl:NamedIndividual ,
                   :MDRRiskClass ;
          rdfs:comment "MDR risk class III. Highest risk for medical devices."@en ;
          rdfs:label "Class III"@en ,
                     "Classe III"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassIIa
:ClassIIa rdf:type owl:NamedIndividual ,
                   :MDRRiskClass ;
          rdfs:comment "MDR risk class IIa. Low to moderate risk for medical devices."@en ;
          rdfs:label "Class IIa"@en ,
                     "Classe IIa"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#ClassIIb
:ClassIIb rdf:type owl:NamedIndividual ,
                   :MDRRiskClass ;
          rdfs:comment "MDR risk class IIb. Moderate to high risk for medical devices."@en ;
          rdfs:label "Class IIb"@en ,
                     "Classe IIb"@ca .


###  http://www.uoc.edu/ontologies/eudamed-mdr-ivdr#Closed
:Closed rdf:type owl:NamedIndividual ,
                 :ActionStatus ;
        rdfs:comment "The corrective action has been completed."@en ;
        rdfs:label "Closed"@en ,
                   "Tancat"@ca .


