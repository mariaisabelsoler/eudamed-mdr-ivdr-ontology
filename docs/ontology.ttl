                     rdfs:label "Single-Use Device Type"@en ,
                                "Tipus Dispositiu d'un Sol Ús"@ca .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :InSituCorrection
                :Recall
                :SafetyAlert
                :UserNotice
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :ActiveDeviceType
                        :ImplantableActiveDeviceType
                        :ImplantableDeviceType
                        :InVitroDiagnosticDeviceType
                        :SelfTestDeviceType
                        :SingleUseDeviceType
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :ClassA
                        :ClassB
                        :ClassC
                        :ClassD
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :ClassI
                        :ClassIII
                        :ClassIIa
                        :ClassIIb
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Closed
                        :Open
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Critical
                        :Moderate
                        :Serious
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :DeviceFailure
                        :DevicePerformance
                        :DeviceSafety
                        :DiagnosticError
                        :PatientHarm
                        :ProductQuality
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Female
                        :Male
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :High
                        :Low
                        :Medium
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :IVDR
                        :MDR
                      )
] .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#a> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#date> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#rc> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdfs:comment "Marks a corrective action as Closed when it has a closure date."@en ;
   rdfs:label "CorrectiveAction Status by closureDate"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :CorrectiveAction ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :closureDate ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#date>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :status ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :Closed
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment "If a device has IVDR as regulatory framework, its risk class must be of type IVDRRiskClass."@en ;
   rdfs:label "IVDR enforces IVDRRiskClass"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :MedicalDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRegulatoryFramework ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :IVDR
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRiskClass ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#rc>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :IVDRRiskClass ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#rc>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment "If a device has MDR as regulatory framework, its risk class must be of type MDRRiskClass."@en ;
   rdfs:label "MDR enforces MDRRiskClass"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :MedicalDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRegulatoryFramework ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :MDR
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRiskClass ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#rc>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :MDRRiskClass ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#rc>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment "Assigns MDR regulatory framework to devices that are not in vitro diagnostic."@en ;
   rdfs:label "MedicalDevice RegulatoryFramework by isIvd"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :isIvd ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> "false"^^xsd:boolean
