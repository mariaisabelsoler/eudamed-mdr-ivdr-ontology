#    Object Properties
#################################################################

###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/addressesIncident
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/addressesIncident> rdf:type owl:ObjectProperty ,
                                                                                                    owl:FunctionalProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                           rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Incident> ;
                                                                                           rdfs:comment "Connects a corrective action to the incident that it addresses."@en ;
                                                                                           rdfs:label "addresses incident"@en ,
                                                                                                      "tracta l'incident"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/affectedDeviceType
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/affectedDeviceType> rdf:type owl:ObjectProperty ;
                                                                                            rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                            rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MedicalDevice> ;
                                                                                            rdfs:comment "Connects a risk to the types of medical devices that it can affect."@en ;
                                                                                            rdfs:label "affected device type"@en ,
                                                                                                       "tipus de dispositiu afectat"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/category
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/category> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Risk> ;
                                                                                  rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/RiskCategory> ;
                                                                                  rdfs:comment "Connects a risk to its general category."@en ;
                                                                                  rdfs:label "categoria"@ca ,
                                                                                             "category"@en .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countriesAffected
<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countriesAffected> rdf:type owl:ObjectProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/CorrectiveAction> ;
                                                                                           rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/GeographicScope> ;
                                                                                           rdfs:comment "Geographic area affected by a corrective action. It can be a single country or a regulatory zone."@en ;
                                                                                           rdfs:label "countries affected"@en ,
                                                                                                      "països afectats"@ca .


###  http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/countryReported
