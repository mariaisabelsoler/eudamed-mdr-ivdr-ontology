                                                                                  rdfs:range <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/Severity> ;
                                                                                  rdfs:comment "Connects a risk to its severity level."@en ;
                                                                                  rdfs:label "gravetat"@ca ,
