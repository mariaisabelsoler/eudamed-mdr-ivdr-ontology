<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIII> rdf:type owl:NamedIndividual ,
                                                                                           <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass> ;
