<http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/ClassIIb> rdf:type owl:NamedIndividual ,
                                                                                           <http://www.semanticweb.org/issoc/ontologies/2026/3/untitled-ontology-9/MDRRiskClass> ;
